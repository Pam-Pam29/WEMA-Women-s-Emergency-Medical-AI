# WEMA — Environment Variables Template
# Copy this file to .env and fill in your real values
# Never commit .env to git

# ── Groq (LLM inference — set this in HF Spaces secrets) ─────────────────────
GROQ_API_KEY=

# ── Twilio (voice calls + SMS alerts — set these in Railway variables) ─────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── HF Spaces inference URL (set this in Railway variables) ───────────────────
HF_SPACES_URL=https://YOUR-USERNAME-wema-inference.hf.space

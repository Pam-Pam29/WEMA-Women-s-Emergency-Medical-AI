TWILIO_ACCOUNT_SID=your_value
TWILIO_AUTH_TOKEN=your_value
TWILIO_PHONE_NUMBER=your_value
DEEPGRAM_API_KEY=your_value
AZURE_SPEECH_KEY=your_value
AZURE_SPEECH_REGION=southafricanorth
GROQ_API_KEY=your_value
APP_BASE_URL=https://your-app.fly.dev


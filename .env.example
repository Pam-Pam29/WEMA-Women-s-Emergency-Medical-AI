# WEMA — Environment Variables Template
# Copy this file to .env and fill in your real values
# Never commit .env to git

# ── Groq (LLM inference) ──────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Africa's Talking (voice calls + SMS alerts) ───────────────────────────────
AT_USERNAME=sandbox          # use 'sandbox' for testing, your username for production
AT_API_KEY=                  # from africastalking.com dashboard
AT_PHONE_NUMBER=             # your AT virtual number e.g. +2341234567890

# ── Deepgram (speech-to-text) ─────────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ── Azure Speech (text-to-speech) ─────────────────────────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southafricanorth

# ── App URL (Railway deployment URL — used to serve TTS audio to AT) ──────────
APP_BASE_URL=https://your-app.up.railway.app
